              Name="st_9cf8c75f9c4f4dd296a68e9d143dd82f"
              VSTAMajorVersion="15"
              VSTAMinorVersion="0"
              Language="VisualBasic">
              <ProjectItem
                Name="My Project\AssemblyInfo.vb"
                Encoding="UTF8"><![CDATA[Imports System
Imports System.Reflection
Imports System.Runtime.InteropServices

