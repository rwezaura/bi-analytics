      DTS:DTSID="{1B5C5F2F-AC3D-4F1B-8CCB-D820BF0F066B}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @ETLBatch int = &quot; + (DT_WSTR, 30) @[User::intETLBatch] + &quot;&#xA;DECLARE @PPN_DT datetime = N'&quot; + (DT_WSTR, 30) (DT_DBDATE) @[User::dtDateToProcess]  + &quot;T00:00:00.000'&#xA;DECLARE @LOGGING smallint = 2&#xA;&#xA;Declare @execution_id bigint&#xA;EXEC [SSISDB].[catalog].[create_execution] @package_name=N'Master_Dimensions_AR_DIM.dtsx', @execution_id=@execution_id OUTPUT, @folder_name=N'&quot; + @[$Project::SSISDBFolder] + &quot;', @project_name=N'Analytics', @use32bitruntime=False, @reference_id=Null&#xA;&#xA;EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'ETLBatchID', @parameter_value=@ETLBatch&#xA;EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'PPN_DT', @parameter_value=@PPN_DT&#xA;EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=50, @parameter_name=N'LOGGING_LEVEL', @parameter_value=@LOGGING&#xA;EXEC [SSISDB].[catalog].[start_execution] @execution_id&#xA;&#xA;DECLARE @DidPackageFail INT &#xA;&#xA;DECLARE @KeepWaiting BIT = 1&#xA;&#xA;DECLARE @ExecutionStatus TINYINT&#xA;&#xA;DECLARE @ErrorMessage NVARCHAR(500)&#xA;&#xA;DECLARE @PackageName varchar(50) = 'Master_Dimensions_AR_DIM.dtsx'&#xA;&#xA; &#xA; &#xA;&#xA;&#xA;WHILE @KeepWaiting = 1&#xA;&#xA;BEGIN&#xA;&#xA;SELECT @ExecutionStatus = STATUS FROM SSISDB.CATALOG.EXECUTIONS WHERE execution_id = @execution_id                   &#xA;&#xA; &#xA;IF @ExecutionStatus IN (1, 2, 5, 8) --status of created, running, pending, stopping&#xA;&#xA;BEGIN&#xA;                                               &#xA; WAITFOR DELAY '00:00:10'&#xA;                                        &#xA;        SET @KeepWaiting = 1&#xA;END&#xA;ELSE                         &#xA;        &#xA;IF @ExecutionStatus IN (4, 6) --status of failed or ended unexpectedtly&#xA;&#x9;&#xA;&#x9;BEGIN&#xA;&#x9;&#x9;/*If you want processing to stop after an error uncomment two code lines below*/&#xA;        &#xA;SET @KeepWaiting = 0                                            &#xA;&#x9;&#x9;SET @DidPackageFail = 1&#xA;&#xA;&#x9;&#x9;END&#xA;ELSE --stop looping statuses without raising error (success, completed, or stopped)                                           &#xA;BEGIN              &#xA;    &#xA;&#x9;SET @KeepWaiting = 0                          &#xA;&#x9;SET @DidPackageFail = 0     &#xA;&#x9;&#x9;                                &#xA;END&#xA;&#xA;END&#xA;&#xA;SELECT @DidPackageFail&quot;"
      DTS:IncludeInDebugDump="2345"
