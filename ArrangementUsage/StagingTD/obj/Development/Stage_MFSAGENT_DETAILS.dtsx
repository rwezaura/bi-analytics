              <ProjectItem
                Name="ScriptMain.vb"
                Encoding="UTF8"><![CDATA['/*
'Copyright � 2013 Pragmatic Works Inc.
'#####################################################################################################################
'LEGAL NOTICE
'#####################################################################################################################
