    Inherits Microsoft.SqlServer.Dts.Tasks.ScriptTask.VSTARTScriptObjectModelBase

    Public Sub Main()

        ' Begin BI xPress Code

Dim sSourceID As String = ReadVariable("System::SourceID").ToString().ToUpper()
  Try
'//DFT CBE_SUBSCRIBER ---- > FF_SRC CBE_SUBSCRIBER
      If sSourceID="{961C00A2-AD16-4560-A869-9FC5BE28185F}" Then
          Dim conn As ConnectionManager
          If (Dts.Connections.Contains("{8BE14B22-CF1B-450A-994F-20962FF7C146}"))
              conn = Dts.Connections("{8BE14B22-CF1B-450A-994F-20962FF7C146}")
          ElseIf (Dts.Connections.Contains("FF_CBE_SUBSCRIBER"))
              conn = Dts.Connections("FF_CBE_SUBSCRIBER")
          Else
              Dts.Events.FireWarning(0,"","Can not log connection FF_CBE_SUBSCRIBER. Re-applying BIxPress Auditing Framework may fix this issue.","",0)
              Exit Try
          End If
          If conn IsNot Nothing Then
          Try
              If Not conn.ConnectionString Is Nothing Then
                  WriteVariable("User::varSSISOps_B3A4C1305EEC41AFB0F4D9557E37D932_RowCount_1_DataObjectConnectionString",conn.ConnectionString)
              End If
          Catch ex As Exception
          End Try
          Try
          Catch ex As Exception
          End Try
          End If
      End If
  Catch ex As Exception
  End Try

  Try
'//DFT CBE_SUBSCRIBER ---- > FF_SRC CBE_SUBSCRIBER
      If sSourceID="{961C00A2-AD16-4560-A869-9FC5BE28185F}" Then
          Dim conn As ConnectionManager
