      DTS:DTSID="{61BF16CE-37C7-4CB2-9D08-3947A2EBDBDE}"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="strPPN_DT"
      DTS:RaiseChangedEvent="True">
      <DTS:VariableValue
        DTS:DataType="8"
        xml:space="preserve"></DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{AC6FE611-F39D-4AC9-BBF7-0DD5F7750BDF}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;UPDATE CCI_ControlTable &#xA;&#x9;&#x9;&#x9;SET SourceFileCount = &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;(SELECT COUNT(DISTINCT FileName) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;FROM &quot; +  @[User::DestinationTable]  + &quot; WITH (NOLOCK) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;WHERE Stage_Audit_Key = '&quot; + (DT_WSTR, 10)@[User::LogID] + &quot;' AND PPN_DT = '&quot; +   (DT_WSTR, 10)@[$Package::PPN_DT] + &quot;') &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;WHERE StageAuditKey = '&quot; + (DT_WSTR, 10)@[User::LogID] + &quot;'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="strUpdateCCI_Control">
      <DTS:VariableValue
        DTS:DataType="8">UPDATE CCI_ControlTable 
			SET SourceFileCount = 
					(SELECT COUNT(DISTINCT FileName) 
					FROM CBSSYS_STAFF_20220404 WITH (NOLOCK) 
					WHERE Stage_Audit_Key = '0' AND PPN_DT = '4/4/2022') 
					WHERE StageAuditKey = '0'</DTS:VariableValue>
    </DTS:Variable>
