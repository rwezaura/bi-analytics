EXEC [SSISDB].[catalog].[create_execution] @package_name=N'', @execution_id=@execution_id OUTPUT, @folder_name=N'Analytics', @project_name=N'Staging', @use32bitruntime=False, @reference_id=Null, @runinscaleout=False
