      DTS:Expression="&quot;UPDATE etl.CCI_ControlTable &#xA;&#x9;&#x9;&#x9;SET SourceFileCount = &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;(SELECT COUNT(DISTINCT FileName) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;FROM &quot; +  @[User::DestinationTable]  + &quot; WITH (NOLOCK) &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;WHERE Stage_Audit_Key = '&quot; + (DT_WSTR, 10)@[User::LogID] + &quot;' AND PPN_DT = '&quot; +   (DT_WSTR, 10)@[$Package::PPN_DT] + &quot;') &#xA;&#x9;&#x9;&#x9;&#x9;&#x9;WHERE StageAuditKey = '&quot; + (DT_WSTR, 10)@[User::LogID] + &quot;'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="strUpdateCCI_Control">
      <DTS:VariableValue
        DTS:DataType="8">UPDATE etl.CCI_ControlTable 
			SET SourceFileCount = 
					(SELECT COUNT(DISTINCT FileName) 
					FROM CBSVOU WITH (NOLOCK) 
					WHERE Stage_Audit_Key = '0' AND PPN_DT = '4/23/2015') 
					WHERE StageAuditKey = '0'</DTS:VariableValue>
    </DTS:Variable>
