			    conn = Dts.Connections["{5CEA29E7-AE35-4E41-A53D-F93E77395C6E}"];
		    } else if ((Dts.Connections.Contains("FF_GFT"))) {
			    conn = Dts.Connections["FF_GFT"];
		    } else {
			    Dts.Events.FireWarning(0,"","Can not log connection FF_GFT. Re-applying BIxPress Auditing Framework may fix this issue.", "", 0);
		    }
          try{
              if (conn.ConnectionString != null) {
                  WriteVariable("User::varSSISOps_FD4D0FA5F3084B40A20CD1793E00C852_RowCount_1_DataObjectName",System.IO.Path.GetFileName(conn.ConnectionString));
              }
          }catch (Exception ex){
          }
          if (conn != null) {
          } //End conn props
      }
  } catch { }

  try{
//DFT GFT ---- > FF_SRC GFT
      if (sSourceID == "{2E06F051-CF47-4338-B47E-0900BA3D2C88}") {
		    ConnectionManager conn = null;
		    if (Dts.Connections.Contains("{5CEA29E7-AE35-4E41-A53D-F93E77395C6E}")) {
			    conn = Dts.Connections["{5CEA29E7-AE35-4E41-A53D-F93E77395C6E}"];
		    } else if ((Dts.Connections.Contains("FF_GFT"))) {
			    conn = Dts.Connections["FF_GFT"];
		    } else {
			    Dts.Events.FireWarning(0,"","Can not log connection FF_GFT. Re-applying BIxPress Auditing Framework may fix this issue.", "", 0);
		    }
          try{
              if (conn.ConnectionString != null) {
                  WriteVariable("User::varSSISOps_FD4D0FA5F3084B40A20CD1793E00C852_RowCount_2_DataObjectName",System.IO.Path.GetFileName(conn.ConnectionString));
              }
          }catch (Exception ex){
          }
          if (conn != null) {
          } //End conn props
      }
  } catch { }

  try{
//DFT GFT ---- > OLE_DST GFT_Stage
      if (sSourceID == "{2E06F051-CF47-4338-B47E-0900BA3D2C88}") {
		    ConnectionManager conn = null;
		    if (Dts.Connections.Contains("")) {
			    conn = Dts.Connections[""];
		    } else if ((Dts.Connections.Contains(""))) {
			    conn = Dts.Connections[""];
		    } else {
			    Dts.Events.FireWarning(0,"","Can not log connection . Re-applying BIxPress Auditing Framework may fix this issue.", "", 0);
		    }
          if (conn != null) {
          } //End conn props
      }
  } catch { }

  try{
//DFT GFT ---- > OLE_DST RJCTN_LOG
      if (sSourceID == "{2E06F051-CF47-4338-B47E-0900BA3D2C88}") {
		    ConnectionManager conn = null;
		    if (Dts.Connections.Contains("")) {
			    conn = Dts.Connections[""];
