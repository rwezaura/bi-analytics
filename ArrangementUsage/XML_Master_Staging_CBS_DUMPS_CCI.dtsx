        --Select @execution_id

        EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'FileFilter', @parameter_value= N'*.unl'
        EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'SourceDirectory', @parameter_value=  N'C:\SRC_DATA\WORK_FOLDER\CBS\DUMP\BC_SUBSCRIBER'
        EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'SourceSystem', @parameter_value= N'CBS-BC_SUBSCRIBER'
        EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'StageTable', @parameter_value= N'_BC_SUBSCRIBER'
        EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=30, @parameter_name=N'TaskQueueInsert', @parameter_value= N'etl.TaskQueue_Insert_Stage'
        DECLARE @var5 smallint = 2

        EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=50, @parameter_name=N'LOGGING_LEVEL', @parameter_value=@var5

        EXEC [SSISDB].[catalog].[start_execution] @execution_id


        DECLARE @KeepWaiting BIT = 1

        DECLARE @ExecutionStatus TINYINT

        DECLARE @ErrorMessage NVARCHAR(500)


        DECLARE @PackageName varchar(50) = 'TQ_Stream_LoadFileNames.dtsx'


        WHILE @KeepWaiting = 1

        BEGIN

        SELECT @ExecutionStatus = STATUS FROM SSISDB.CATALOG.EXECUTIONS WHERE execution_id = @execution_id


        IF @ExecutionStatus IN (1, 2, 5, 8) --status of created, running, pending, stopping

        BEGIN
        WAITFOR DELAY '00:00:10'
        SET @KeepWaiting = 1

        END
        ELSE
        IF @ExecutionStatus IN (4, 6) --status of failed or ended unexpectedtly

