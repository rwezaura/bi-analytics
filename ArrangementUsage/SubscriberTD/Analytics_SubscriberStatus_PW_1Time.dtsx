                  componentClassID="Microsoft.Lookup"
                  contactInfo="Lookup;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;6"
                  description="Joins additional columns to the data flow by looking up values in a table. For example, join to the 'employee id' column the employees table to get 'hire date' and 'employee name'. We recommend this transformation when the lookup table can fit into memory."
                  name="LKP Region and Technology"
                  usesDispositions="true"
                  version="6">
                  <properties>
                    <property
                      dataType="System.String"
                      description="Specifies the SQL statement that generates the lookup table."
                      expressionType="Notify"
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT
	a.UNQ_CD_SRC_STM 'CELLID'
	, c.PRVNC_NM 'REGION_LKP'
	, case when d.NTW_NM ='Unknown' then NULL else d.NTW_NM end  'Technology'
FROM
	dbo.SCTR_DIM a
INNER JOIN
	dbo.BTS_DIM b
ON
	left(right(a.UNQ_CD_SRC_STM,9),4)+right(a.UNQ_CD_SRC_STM,4) = b.UNQ_CD_SRC_STM 
INNER JOIN
	dbo.GEO_DIM c
ON
	b.GEO_KEY = c.GEO_KEY
INNER JOIN
	dbo.NTW_DIM d
ON
	b.NTW_KEY = d.NTW_KEY</property>
                    <property
                      dataType="System.String"
                      description="Specifies a SQL statement that uses parameters to generate the lookup table."
                      expressionType="Notify"
                      name="SqlCommandParam"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select * from (SELECT
	a.UNQ_CD_SRC_STM 'CELLID'
	, c.PRVNC_NM 'REGION_LKP'
	, case when d.NTW_NM ='Unknown' then NULL else d.NTW_NM end  'Technology'
FROM
	dbo.SCTR_DIM a
INNER JOIN
	dbo.BTS_DIM b
ON
	left(right(a.UNQ_CD_SRC_STM,9),4)+right(a.UNQ_CD_SRC_STM,4) = b.UNQ_CD_SRC_STM 
INNER JOIN
	dbo.GEO_DIM c
ON
	b.GEO_KEY = c.GEO_KEY
INNER JOIN
	dbo.NTW_DIM d
ON
	b.NTW_KEY = d.NTW_KEY) [refTable]
where [refTable].[CELLID] = ?</property>
