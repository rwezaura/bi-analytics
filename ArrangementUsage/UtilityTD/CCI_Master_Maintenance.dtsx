          DTS:DTSID="{ed83b167-39cb-4f5a-a3fa-6a455a1c7070}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="SQL Partition Switch CCI Tables"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2014; © 2014 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A3611220-B52B-4CFD-93D2-B5519D55FB32}"
              SQLTask:SqlStatementSource="Declare @execution_id bigint&#xA;EXEC [SSISDB].[catalog].[create_execution] @package_name=N'CCI_PartitionSwitch.dtsx', @execution_id=@execution_id OUTPUT, @folder_name=N'Analytics', @project_name=N'Utility', @use32bitruntime=False, @reference_id=Null&#xA;--Select @execution_id&#xA;DECLARE @var0 smallint = 2&#xA;EXEC [SSISDB].[catalog].[set_execution_parameter_value] @execution_id,  @object_type=50, @parameter_name=N'LOGGING_LEVEL', @parameter_value=@var0&#xA;EXEC [SSISDB].[catalog].[start_execution] @execution_id&#xA;&#xA;DECLARE @KeepWaiting BIT = 1&#xA;DECLARE @ExecutionStatus TINYINT&#xA;DECLARE @ErrorMessage NVARCHAR(500)&#xA;DECLARE @PackageName varchar(50) = 'Stage_CCI_PartitionSwitch.dtsx'&#xA;&#xA;WHILE @KeepWaiting = 1&#xA;BEGIN&#xA;&#xA;SELECT @ExecutionStatus = STATUS FROM SSISDB.CATALOG.EXECUTIONS WHERE execution_id = @execution_id&#xA;IF @ExecutionStatus IN (1, 2, 5, 8) --status of created, running, pending, stopping&#xA;  &#xA;BEGIN&#xA;   WAITFOR DELAY '00:00:10'&#xA;   SET @KeepWaiting = 1&#xA;END&#xA; ELSE&#xA;  IF @ExecutionStatus IN (4, 6) --status of failed or ended unexpectedtly&#xA;   &#xA;BEGIN   /*If you want processing to stop after an error uncomment two code lines below*/&#xA;    &#xA; RAISERROR (N'Partition Switch operation failed, please check execution status on Stage_CCI_PartitionSwitch.dtsx', 16, 1)&#xA;    &#xA; SET @KeepWaiting = 0&#xA; SELECT 1   -- If Failure occurs we populate a variable in the package with a value of 1 (True for child package failed)&#xA; &#xA;END&#xA;  &#xA;ELSE --stop looping statuses without raising error (success, completed, or stopped)&#xA;   &#xA;BEGIN&#xA;    &#xA;SET @KeepWaiting = 0&#xA;SELECT 0   -- If NO failure occurs we populate a variable in the package with a value of 0 (False for child package failed)&#xA;&#xA;END&#xA;END&#xA;"
              SQLTask:ResultType="ResultSetType_SingleRow" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="0"
                SQLTask:DtsVariableName="User::intPartitionSwitchFail" />
            </SQLTask:SqlTaskData>
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\SEQC Page Compression Maintenance\SQL Stop Reconciliation Job"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{9DB5F772-4283-46F8-88DD-B562E5EFFB85}"
