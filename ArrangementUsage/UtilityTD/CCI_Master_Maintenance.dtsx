          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A3611220-B52B-4CFD-93D2-B5519D55FB32}"
              SQLTask:SqlStatementSource="IF EXISTS(&#xA;&#x9;&#x9;SELECT TOP (1) * FROM(&#xA;&#x9;&#x9;SELECT top(1) *&#xA;&#x9;&#x9;  FROM [msdb].[dbo].[sysjobactivity]&#xA;&#x9;&#x9;  where &#xA;&#x9;&#x9;&#x9;job_id = '289D8D09-D7A5-411D-8F58-17285AAFF0DE' AND start_execution_date IS NOT NULL&#xA;&#x9;&#x9;&#x9;ORDER BY start_execution_date desc) x&#xA;&#x9;&#x9;where&#xA;&#x9;&#x9;&#x9;x.stop_execution_date is null)&#xA;&#xA;&#x9;BEGIN&#xA;&#x9;&#x9;USE msdb;&#xA;&#xA;&#x9;&#x9;&#x9;EXEC dbo.sp_stop_job&#xA;&#x9;&#x9;&#x9;&#x9;N'Reconciliation_Live' ;&#xA;&#x9;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
