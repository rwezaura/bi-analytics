          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A3611220-B52B-4CFD-93D2-B5519D55FB32}"
              SQLTask:SqlStatementSource="USE msdb;&#xA;GO&#xA;&#xA;EXEC dbo.sp_update_job&#xA;    @job_name = N'Reconciliation_Live',&#xA;    @new_name = N'Reconciliation_Live',&#xA;    @description = N'Job Disabled while recreating views for CCI Tables.',&#xA;    @enabled = 0 ;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
