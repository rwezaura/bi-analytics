          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A3611220-B52B-4CFD-93D2-B5519D55FB32}"
              SQLTask:SqlStatementSource="&#xA;USE msdb;&#xA;GO&#xA;&#xA;EXEC dbo.sp_update_job&#xA;    @job_name = N'Reconciliation_Live',&#xA;    @new_name = N'Reconciliation_Live',&#xA;    @description = N'Job enabled during non maintenance hours.',&#xA;    @enabled = 1 ;&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\SEQC Page Compression Maintenance\SQL Partition Switch CCI Tables"
