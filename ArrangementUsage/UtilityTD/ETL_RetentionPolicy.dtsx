              SQLTask:SqlStatementSource=" SELECT &#xA;&#x9;TBL_NM,&#xA;&#x9;DATEADD(DD, RTNTN_PRD * -1, CAST(GETDATE() AS DATE))&#x9;&#x9;&#x9;&#x9;AS&#x9;EndDate,&#xA;&#x9;CASE WHEN LastProcessed = '1/1/1900' THEN '1/1/2013'&#xA;&#x9;ELSE LastProcessed end AS  StartDate&#xA;&#xA;FROM &#xA;&#x9;etl.Retention_Policy&#xA;WHERE&#xA;&#x9;ACTIVE_FLAG = 1 AND&#xA;&#x9;IsPartitioned = 0 AND&#xA;&#x9;LAYER = 'ANALYTICS'"
