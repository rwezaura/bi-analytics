        <AnnotationLayout
          Text="EXEC [dbo].[CCI_ListOfTables_Create]&#xA;Step 1 - Get a List of dates per stream from the CCI_Process Table.&#xA;              Also we want to add three additional days for the current &#xA;              day and next couple days.&#xA;&#xA;EXEC [dbo].[CreatePageCompressionTable]&#xA;Step 2 - Loop through all days and streams and create page &#xA;              compression tables if necessary."
          ParentId="Package"
          FontInfo="{assembly:Null}"
          Size="380,152"
          Id="a3e0ad3c-3395-4c4a-8266-60d80dc22abc"
          TopLeft="612,167" />
        <AnnotationLayout
          Text="This package creates Page Compression tables for the Column Compression ETL Design &#xA;pattern. Only the larger CDRs that are part of the new ETL design pattern utilize Page&#xA;Compression tables before being loaded into Column Compressed tables (Rec,Data,SMS).&#xA;At this time smaller streams like MGR and VOU are loaded directly into Column Compression&#xA;tables. - MP"
          ParentId="Package"
          FontInfo="{assembly:Null}"
