      DTS:DTSID="{61F0A4AD-CC92-4875-9F62-C6F7239B7702}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;IF OBJECT_ID('&quot; + @[User::partmgmt_StagingTableName_New] + &quot;', 'U') IS NOT NULL&#xA; &#xA;BEGIN&#xA;&#x9;IF NOT EXISTS (SELECT TOP 1 * FROM &quot; + @[User::partmgmt_StagingTableName_New] + &quot; ) &#xA;&#x9;&#x9;BEGIN&#x9;  DROP TABLE &quot; + @[User::partmgmt_StagingTableName_New] + &quot; END END&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="strDropTable">
      <DTS:VariableValue
        DTS:DataType="8">IF OBJECT_ID('CBSREC_20150201', 'U') IS NOT NULL
 
BEGIN
	IF NOT EXISTS (SELECT TOP 1 * FROM CBSREC_20150201 ) 
		BEGIN	  DROP TABLE CBSREC_20150201 END END</DTS:VariableValue>
    </DTS:Variable>
