      <DTS:VariableValue
        DTS:DataSubType="ManagedSerializable"
        DTS:DataType="13">
        <SOAP-ENV:Envelope xmlns:clr="http://schemas.microsoft.com/soap/encoding/clr/1.0" xmlns:SOAP-ENC="http://schemas.xmlsoap.org/soap/encoding/" xmlns:SOAP-ENV="http://schemas.xmlsoap.org/soap/envelope/" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          SOAP-ENV:encodingStyle="http://schemas.xmlsoap.org/soap/encoding/">
          <SOAP-ENV:Body>
            <xsd:anyType
              id="ref-1"></xsd:anyType>
          </SOAP-ENV:Body>
        </SOAP-ENV:Envelope>
      </DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{37978BA4-095F-4548-B015-C05C81CDF142}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="(MONTH(@[User::PPN_DT]) == 1 ? &quot;January&quot; : MONTH(@[User::PPN_DT]) == 2 ? &quot;February&quot; : MONTH(@[User::PPN_DT]) == 3 ? &quot;March&quot; :&#xA;MONTH(@[User::PPN_DT]) == 4 ? &quot;April&quot; : MONTH(@[User::PPN_DT]) == 5 ? &quot;May&quot; : MONTH(@[User::PPN_DT]) == 6 ? &quot;June&quot; :&#xA;MONTH(@[User::PPN_DT]) == 7 ? &quot;July&quot; : MONTH(@[User::PPN_DT]) == 8 ? &quot;August&quot; : MONTH(@[User::PPN_DT]) == 9 ? &quot;September&quot; :&#xA;MONTH(@[User::PPN_DT]) == 10 ? &quot;October&quot; : MONTH(@[User::PPN_DT]) == 11 ? &quot;November&quot; :&#xA;MONTH(@[User::PPN_DT]) == 12 ? &quot;December&quot; : &quot;InvalidMonth&quot;)"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="PPN_DT_MonthName">
      <DTS:VariableValue
        DTS:DataType="8">April</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{4B845AD7-01E4-4D8F-9361-DBC7234926C7}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="DATEPART( &quot;yyyy&quot;, @[User::PPN_DT] )"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="PPN_DT_Year">
      <DTS:VariableValue
        DTS:DataType="3">2015</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{B558F826-0C94-4BEE-9428-C11DAC6A55B0}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;select DT&#xA;from DT_DIM d&#xA;&#xA;where DT  between dateadd(day,&quot; + (DT_STR, 3, 1252) @[User::intDayRangeValue]  + &quot;,getdate())  and dateadd(day,&quot; + (DT_STR, 3, 1252) @[$Package::DayRangeValue] + &quot;,getdate()) ORDER BY 1&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="sqlGetDaysQuery">
      <DTS:VariableValue
        DTS:DataType="8">select DT
from DT_DIM d

where DT  between dateadd(day,11,getdate())  and dateadd(day,120,getdate()) ORDER BY 1</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:Description="SSISOps : DON'T CHANGE PREFIX. This variable (introduced in v3.2) controls execution of all event handlers for BIxPress Auditing Framework. Set this variable to True or -1 if you want to disable auditing framework related code inside all eventhandlers. You may also have to set Package.LoggingMode=2 along with this variable if you want to disable framework completely."
