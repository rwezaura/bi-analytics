      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;CREATE CLUSTERED COLUMNSTORE INDEX CCIX_&quot; + @[User::partmgmt_StagingTableName]  + &quot;_CCI ON &quot; + @[User::partmgmt_StagingTableName_New]  + &quot; WITH (DROP_EXISTING = ON) ON ps_daily(PPN_DT);&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="strAddClusteredColumnStore">
      <DTS:VariableValue
        DTS:DataType="8">CREATE CLUSTERED COLUMNSTORE INDEX CCIX_CBSREC_CCI ON CBSREC_20150201 WITH (DROP_EXISTING = ON) ON ps_daily(PPN_DT);</DTS:VariableValue>
    </DTS:Variable>
