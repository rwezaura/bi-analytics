    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{E0B07762-4F7A-47B5-A87B-73E7186547B1}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;ALTER TABLE &quot; +  @[User::partmgmt_StagingTableName_New]  + &quot; SWITCH &quot; + &quot; PARTITION &quot; +  @[User::partmgmt_PartitionNbr] + &quot; TO &quot; +  @[User::partmgmt_SchemaName] + &quot;.&quot; + @[User::partmgmt_StagingTableName]   + &quot; PARTITION &quot; +  @[User::partmgmt_PartitionNbr]"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="partmgmt_SwitchSQL">
      <DTS:VariableValue
        DTS:DataType="8">ALTER TABLE CBSREC_20150201 SWITCH  PARTITION  TO dbo.CBSREC PARTITION </DTS:VariableValue>
    </DTS:Variable>
