      DTS:DTSID="{0288D3E4-1F03-4D4F-957C-6F1D8234F2CB}"
      DTS:Expression="@[User::partmgmt_StagingTableName] + &quot;_&quot; + REPLACE( (DT_STR, 10, 1252) (DT_DBDATE) @[User::PPN_DT], &quot;-&quot;, &quot;&quot;)"
