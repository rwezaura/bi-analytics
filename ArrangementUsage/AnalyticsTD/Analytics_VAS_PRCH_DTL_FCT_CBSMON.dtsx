7" dir="TRAN"  typ="trnlookup" name="LKP VAS SERVICE DETAIL FACT UNIQUE RECORDS" pid="{09D47FF7-CC5E-4FE7-AEBC-FFEF5258E5E8}_197" /&gt;&lt;com id="229" dir="TRAN"  typ="trnlookup" name="LKP WALLET KEY" pid="{09D47FF7-CC5E-4FE7-AEBC-FFEF5258E5E8}_229" /&gt;&lt;com id="256" dir="DEST"  typ="desoledb" name="OLE_DST VAS_PRCH_DTL_FACT" pid="{09D47FF7-CC5E-4FE7-AEBC-FFEF5258E5E8}_256" /&gt;&lt;com id="309" dir="SRC"  typ="srcoledb" name="OLE_SRC VAS_SVC_DTL_FCT" pid="{09D47FF7-CC5E-4FE7-AEBC-FFEF5258E5E8}_309" /&gt;&lt;com id="372" dir="TRAN"  typ="trnrowcount" name="SRC OLE_SRC VAS_SVC_DTL_FCT" pid="{09D47FF7-CC5E-4FE7-AEBC-FFEF5258E5E8}_372" /&gt;&lt;dp id="376" val="0"  ann="" c1="2" c2="116"/&gt;&lt;dp id="377" val="0"  ann="" c1="48" c2="141"/&gt;&lt;dp id="378" val="0"  ann="" c1="23" c2="197"/&gt;&lt;dp id="379" val="0"  ann="" c1="35" c2="168"/&gt;&lt;dp id="380" val="0"  ann="" c1="14" c2="62"/&gt;&lt;dp id="381" val="0"  ann="" c1="116" c2="229"/&gt;&lt;dp id="382" val="0"  ann="" c1="229" c2="35"/&gt;&lt;dp id="383" val="0"  ann="" c1="66" c2="14"/&gt;&lt;dp id="384" val="0"  ann="" c1="141" c2="91"/&gt;&lt;dp id="385" val="0"  ann="" c1="91" c2="23"/&gt;&lt;dp id="386" val="0"  ann="" c1="168" c2="48"/&gt;&lt;dp id="387" val="0"  ann="" c1="197" c2="66"/&gt;&lt;dp id="388" val="0"  ann="" c1="309" c2="372"/&gt;&lt;dp id="389" val="0"  ann="" c1="62" c2="256"/&gt;&lt;dp id="390" val="0"  ann="" c1="372" c2="2"/&gt;&lt;/tsk&gt;&lt;tsk id="{8A36971A-D9FC-48B8-B7E7-B234012E78C3}" typ="SQLTask" p="" name="SQL Get LogID" on="1" /&gt;&lt;tsk id="{C433E78D-C6CF-49FA-91DB-A1807D2B79F0}" typ="SQLTask" p="" name="SQL Get SRC_OBJ_KEY" on="1" /&gt;&lt;pc id="{893AA154-90EC-4945-B726-909B6D592942}" op="2" and="True" val="0" task1="{8A36971A-D9FC-48B8-B7E7-B234012E78C3}" task2="{C433E78D-C6CF-49FA-91DB-A1807D2B79F0}" p="" refId="Package.PrecedenceConstraints[Constraint]"/&gt;&lt;pc id="{218D2C23-01A5-462D-B92D-6C2175951AEE}" op="2" and="True" val="0" task1="{C433E78D-C6CF-49FA-91DB-A1807D2B79F0}" task2="{09D47FF7-CC5E-4FE7-AEBC-FFEF5258E5E8}" p="" refId="Package.PrecedenceConstraints[Constraint 1]"/&gt;&lt;/xml&gt;</DTS:VariableValue>
