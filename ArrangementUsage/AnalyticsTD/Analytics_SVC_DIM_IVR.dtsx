              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE_SRC SERVICE"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT [ETLBatchID]
      ,[STAGE_AUDIT_KEY]
      ,[FileName]
      ,[Base_Transceiver_Station_ID]
      ,[Base_Transceiver_Station_Code]
      ,[Base_Transceiver_Station_Short_Name]
      ,[Base_Transceiver_Station_Name]
      ,[City_Code]
      ,[City_Name]
      ,[Technology_Code]
      ,RIGHT(RTRIM([Technology_Name]) ,2) AS [Technology_Name]
      ,[Latitude]
      ,[Longitude]
      ,[BTS_Category_Code]
      ,[BTS_Category_Name]
      ,[Cluster_Code]
      ,[Cluster_Name]
      ,[Cluster_Category_Code]
      ,[Cluster_Category_Name]
      ,[BTS_Long_Name]
      ,[Sector_Quantity]
      ,ISNULL(CAST(REPLACE(Cover_Ratio, '', NULL) AS NUMERIC(18,0)), 0) AS [Cover_Ratio]
      ,[Link_Type_Code]
      ,[Link_Type_Name]
      ,[Distribution_Circuit]
      ,CONVERT(DATE, 
			(CASE [Start_Service_Date] 
				WHEN '' THEN '1900/01/01'
				ELSE SUBSTRING([Start_Service_Date], 7,4) + '/' 
			+ SUBSTRING([Start_Service_Date], 4,2) + '/' 
			+ SUBSTRING([Start_Service_Date], 1,2) 
				END), 102) AS [Start_Service_Date]
      ,CONVERT(DATE, 
			(CASE [End_Service_Date] 
				WHEN '' THEN '1900/01/01'
				ELSE SUBSTRING([End_Service_Date], 7,4) + '/' 
			+ SUBSTRING([End_Service_Date], 4,2) + '/' 
			+ SUBSTRING([End_Service_Date], 1,2) 
				END), 102) AS [End_Service_Date]
      ,[Geography_Code]
      ,[Country_Code]
      ,[Country_Name]
      ,[Geography_Type_Code]
      ,[Geography_Type_Name]
      ,[Territory_Code]
      ,[Territory_Name]
      ,[Region_Code]
      ,[Region_Name]
      ,[DISTRICT]
      ,[REGION]
      ,[CIRCUIT]
      ,[SUBAREA]
      ,[AREA]
      ,[TERRITORY]
      ,CAST(HASHBYTES('MD5',[Base_Transceiver_Station_Name]) AS Binary(20)) AS [CONTROL_MD5]
FROM [dbo].[BTS_DETAILS]
WHERE [Stage_Audit_Key] &gt; ?</property>
                <property
