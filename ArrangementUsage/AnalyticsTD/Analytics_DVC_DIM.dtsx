              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="OLE_SRC DVC_DIM"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT  [ETLBatchID]
      ,[STAGE_AUDIT_KEY]
      ,[FileName]
      ,[PRODUCTKEY]
      ,[APPLYTIME]
      ,[EXPIRETIME]
      ,[VERSION]
      ,[PRODUCTCODE]
      ,[ISBUNDLE]
      ,[BRANDID]
      ,[MAINTYPE]
      ,[PRODSUBTYPE]
      ,[SUBSCRIBETYPE]
      ,[NETWORKTYPE]
      ,[STATUS]
      ,[PRODUCTRENTPRIOR]
      ,[PRODUCTRATEPRIOR]
      ,[MULTISERVICEFLAG]
      ,[CATALOGID]
      ,[HASSUBSCRIBERCODE]
      ,[HASCHARACTERCODE]
      ,[SERIES]
      ,[USAGE]
      ,[INVENTORYSPEC]
      ,[PAIDMODE]
      ,[EFFTYPE]
      ,[EFFMODE]
      ,[EFFVAL]
      ,[EXPTYPE]
      ,[EXPMODE]
      ,[EXPVAL]
      ,[RELEASER]
      ,[RELEASEDATE]
      ,[RELEASERDEPARTMENT]
      ,[CREOPERID]
      ,[CREDATE]
      ,[CREDEPTID]
      ,[LASTUPDOPERID]
      ,[LASTUPDDATE]
      ,[LASTUPDDEPTID]
      ,[NAME_LANG1]
      ,[NAME_LANG2]
      ,[NAME_LANG3]
      ,[NOTE_LANG1]
      ,[NOTE_LANG2]
      ,[NOTE_LANG3]
      ,[EXTERNPRODUCTTYPE]
      ,[EXTERNPRODUCTBRAND]
      ,[SERVICEPROVIDER]
      ,[RELATEDPRODUCT]
      ,[INSIDEPRODUCTCODE]
      ,[PRODUCTCLASSBYSRV]
      ,[CHARGEUSAGETYPE]
      ,[CYCLETYPE]
      ,[CYCLEUNIT]
      ,[CYCLELENGTH]
      ,[CYCLESTSRTFLAG]
      ,[CYCLESTARTDAY]
      ,[RENTTIMEFLAG]
      ,[DATASRVCHARGEMODE]
      ,[SPID]
      ,'GHANA' as CTY_NM
     ,CAST(HASHBYTES('MD5',[PRODUCTKEY]) AS Binary(20)) AS [CONTROL_MD5]
      ,'Cedi' AS CCY_NM
  FROM [dbo].[MAINAPPPROD]
  WHERE [STAGE_AUDIT_KEY] &gt; ? AND MAINTYPE &lt;&gt;  0</property>
                <property
                  dataType="System.String"
                  description="The variable that contains the SQL command to be executed."
                  name="SqlCommandVariable">User::Query_OLE_SRC_PD</property>
                <property
                  dataType="System.Int32"
