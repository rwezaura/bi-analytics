    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{598C9E65-E7C1-448A-A7B8-692E69949A89}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;with dates ([Date]) as (&#xA;    Select convert(datetime,'&quot; + (DT_STR,50,1252)@[User::dtStartDate]  + &quot;') as [Date] -- Put the start date here&#xA;&#xA;    union all &#xA;&#xA;    Select dateadd(day, 1, [Date])&#xA;    from dates&#xA;    where [Date] &lt; '&quot; + (DT_STR,50,1252)@[User::dtEndDate]  + &quot;' -- Put the end date here &#xA;)&#xA;&#xA;select [Date]&#xA;from dates&#xA;option (maxrecursion 32767)&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="strGet_PPN_DTs">
      <DTS:VariableValue
        DTS:DataType="8">with dates ([Date]) as (
    Select convert(datetime,'10/21/2024') as [Date] -- Put the start date here

    union all 

    Select dateadd(day, 1, [Date])
    from dates
    where [Date] &lt; '10/21/2024' -- Put the end date here 
)

select [Date]
from dates
option (maxrecursion 32767)</DTS:VariableValue>
    </DTS:Variable>
