        public string ReadTextFile(string filename)
        {
            string functionReturnValue = null;
            System.IO.StreamReader sr = new System.IO.StreamReader(filename);
            functionReturnValue = sr.ReadToEnd();
            sr.Close();
            return functionReturnValue;
