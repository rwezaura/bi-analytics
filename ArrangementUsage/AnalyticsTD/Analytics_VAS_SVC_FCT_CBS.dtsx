              refId="Package\DFT Create Inferred members ShortCodes\LKP Service Name 3"
              componentClassID="Microsoft.Lookup"
              contactInfo="Lookup;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;6"
              description="Joins additional columns to the data flow by looking up values in a table. For example, join to the 'employee id' column the employees table to get 'hire date' and 'employee name'. We recommend this transformation when the lookup table can fit into memory."
              name="LKP Service Name 3"
              usesDispositions="true"
              version="6">
              <properties>
                <property
                  dataType="System.String"
                  description="Specifies the SQL statement that generates the lookup table."
                  expressionType="Notify"
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">;WITH ShortCodeRanges
AS
(
SELECT
	SVC_KEY
	, SVC_NM
	, SVC_ALT_CD
	, SVC_LONG_NBR
	, SVC_SHORT_NBR_MATCH_LEN
	, SVC_SHORT_NBR_MATCH_LEN - LEN(SVC_ALT_CD) 'ExtraDigits'
	, 0 'MinRange'
	, CAST(LEFT('9999999999', (SVC_SHORT_NBR_MATCH_LEN - LEN(SVC_ALT_CD))) AS BIGINT) 'MaxRange'
FROM
	dbo.SVC_DIM
WHERE
	SVC_SHORT_NBR_MATCH_LEN &lt;&gt; LEN(SVC_ALT_CD)
	AND SVC_NM LIKE '%-MO'
	AND SVC_SHORT_NBR_MATCH_LEN &gt; 0
	AND (SVC_SHORT_NBR_MATCH_LEN - LEN(SVC_ALT_CD)) &lt;= 3
)
SELECT
	SVC_KEY
	, SVC_LONG_NBR + CAST(Number AS VARCHAR) 'RangeLongNumber'
FROM
	ShortCodeRanges a
INNER JOIN
	etl.Numbers b
ON
	b.Number BETWEEN a.MinRange AND a.MaxRange</property>
                <property
                  dataType="System.String"
                  description="Specifies a SQL statement that uses parameters to generate the lookup table."
                  expressionType="Notify"
                  name="SqlCommandParam"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select * from (;WITH ShortCodeRanges
AS
(
SELECT
	SVC_KEY
	, SVC_NM
	, SVC_ALT_CD
	, SVC_LONG_NBR
	, SVC_SHORT_NBR_MATCH_LEN
	, SVC_SHORT_NBR_MATCH_LEN - LEN(SVC_ALT_CD) 'ExtraDigits'
	, 0 'MinRange'
	, CAST(LEFT('9999999999', (SVC_SHORT_NBR_MATCH_LEN - LEN(SVC_ALT_CD))) AS BIGINT) 'MaxRange'
FROM
	dbo.SVC_DIM
WHERE
	SVC_SHORT_NBR_MATCH_LEN &lt;&gt; LEN(SVC_ALT_CD)
	AND SVC_NM LIKE '%-MO'
	AND SVC_SHORT_NBR_MATCH_LEN &gt; 0
	AND (SVC_SHORT_NBR_MATCH_LEN - LEN(SVC_ALT_CD)) &lt;= 3
)
SELECT
	SVC_KEY
	, SVC_LONG_NBR + CAST(Number AS VARCHAR) 'RangeLongNumber'
FROM
	ShortCodeRanges a
INNER JOIN
	etl.Numbers b
ON
	b.Number BETWEEN a.MinRange AND a.MaxRange) [refTable]
where [refTable].[RangeLongNumber] = ?</property>
