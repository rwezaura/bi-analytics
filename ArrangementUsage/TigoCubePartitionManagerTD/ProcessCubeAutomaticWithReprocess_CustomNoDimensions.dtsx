            <SQLTask:SqlTaskData
              SQLTask:Connection="{4A4368D7-383C-4308-9C5A-357CEA82BA4F}"
              SQLTask:SqlStatementSource="DECLARE @ProcessTable TABLE (&#xA;LoadDates INT&#xA;, ETLBatchID int&#xA;)&#xA;&#xA;INSERT INTO @ProcessTable(LoadDates, ETLBatchID)&#xA;SELECT  CAST(CONVERT(VARCHAR,PPN_DT ,112) AS INT) AS LoadDates&#xA;, ETLBatchID&#xA;FROM ETLBatch&#xA;WHERE Status = 1&#xA;AND layer = 'Analytics'&#xA;AND PartitionProcessed = 0&#xA;&#xA;&#xA;&#xA;UNION ALL&#xA;&#xA;SELECT  CAST(CONVERT(VARCHAR,DATEADD(DD,-1,PPN_DT) ,112) AS INT) AS LoadDates&#xA;, ETLBatchID  AS MAXETLBatchID&#xA;FROM ETLBatch&#xA;WHERE Status = 1&#xA;AND layer = 'Analytics'&#xA;AND PartitionProcessed = 0&#xA;&#xA;&#xA;&#xA;SELECT LoadDates, MAX(ETLBatchID) AS MAXETLBatchID&#xA;FROM @ProcessTable&#xA;GROUP BY LoadDates&#xA;ORDER BY  LoadDates DESC"
              SQLTask:ResultType="ResultSetType_Rowset" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="0"
                SQLTask:DtsVariableName="User::LoadDates" />
