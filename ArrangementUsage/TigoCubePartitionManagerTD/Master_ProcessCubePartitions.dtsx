d Count.PrecedenceConstraints[Constraint]"/&gt;&lt;tsk id="{95C0CC76-6E0B-4634-9DC2-7778028733F7}" typ="SQLTask" p="{F7276349-1842-45CA-92D0-80B4D1BD52B5}" name="SQL ThreadCheckCount" on="1" /&gt;&lt;tsk id="{912A2EBC-02EE-480B-AD09-215C3B68F184}" typ="PW.TASKFACTORY.TIMERTASK.TIMERTASK" p="{F7276349-1842-45CA-92D0-80B4D1BD52B5}" name="TF Timer Task" on="1" /&gt;&lt;tsk id="{754CEEE6-A741-4782-9510-A73CD34B14A4}" typ="SQLTask" p="{CC08A9F9-47D0-49C4-8D9F-B122A51DB0EE}" name="SQL Execute Fact Process Partitions" on="1" /&gt;&lt;tsk id="{7043DD95-6740-472C-9DB0-5BF0C8F30FEB}" typ="ForEachLoopContainer" p="{8EFB134A-4CBA-4EDF-89BB-E0BD1553A3A6}" name="FELC Create Partitions" on="1"  tag1="User::MaxMeasureGroupDate"/&gt;&lt;tsk id="{F8CB75C5-C477-4FDD-9E73-21C613D511E4}" typ="ExecutePackageTask" p="{7043DD95-6740-472C-9DB0-5BF0C8F30FEB}" name="EPT Call Cube Create Partitions" on="1" /&gt;&lt;tsk id="{173B661A-DDBA-4263-9D95-E537CD82FDD5}" typ="ForLoop" p="{8EFB134A-4CBA-4EDF-89BB-E0BD1553A3A6}" name="FLC Running Indicator" on="1" /&gt;&lt;pc id="{7470D6AB-188C-4F3F-AA47-C0763DB042FA}" op="2" and="True" val="0" task1="{CD972418-3BAC-46C4-8C6C-F323C205EA55}" task2="{720C3244-C1E8-4F4E-9A78-D1E6E8EA7650}" p="{173B661A-DDBA-4263-9D95-E537CD82FDD5}" refId="Package\SEQ Process Measure Groups\FEL Measure Group\FLC Running Indicator.PrecedenceConstraints[Constraint]"/&gt;&lt;tsk id="{CD972418-3BAC-46C4-8C6C-F323C205EA55}" typ="SQLTask" p="{173B661A-DDBA-4263-9D95-E537CD82FDD5}" name="SQL ThreadCompleteCheck" on="1" /&gt;&lt;tsk id="{720C3244-C1E8-4F4E-9A78-D1E6E8EA7650}" typ="PW.TASKFACTORY.TIMERTASK.TIMERTASK" p="{173B661A-DDBA-4263-9D95-E537CD82FDD5}" name="TF Timer Task" on="1" /&gt;&lt;tsk id="{1BF4D77D-79EB-498E-8D66-B8EDA56F3742}" typ="SQLTask" p="{A702CE59-0076-442E-82B3-B3ABE9B0641F}" name="SQL Get LoadDates" on="1" /&gt;&lt;/xml&gt;</DTS:VariableValue>
