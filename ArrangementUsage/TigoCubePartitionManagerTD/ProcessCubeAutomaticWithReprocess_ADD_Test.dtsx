        <DTS:Executable
          DTS:refId="Package\SEQ Process Measure Groups\SQL Get LoadDates"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{50073141-F3A8-4FED-8603-2B6CD397E2AA}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="SQL Get LoadDates"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2012; © 2007 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{4A4368D7-383C-4308-9C5A-357CEA82BA4F}"
              SQLTask:SqlStatementSource="DECLARE @ProcessTable TABLE (&#xA;LoadDates INT&#xA;, ETLBatchID int&#xA;)&#xA;&#xA;INSERT INTO @ProcessTable(LoadDates, ETLBatchID)&#xA;SELECT  CAST(CONVERT(VARCHAR,PPN_DT ,112) AS INT) AS LoadDates&#xA;, ETLBatchID&#xA;FROM ETLBatch&#xA;WHERE Status = 1&#xA;AND layer = 'Analytics'&#xA;AND PartitionProcessed = 0&#xA;&#xA;&#xA;&#xA;UNION ALL&#xA;&#xA;SELECT  CAST(CONVERT(VARCHAR,DATEADD(DD,-1,PPN_DT) ,112) AS INT) AS LoadDates&#xA;, ETLBatchID  AS MAXETLBatchID&#xA;FROM ETLBatch&#xA;WHERE Status = 1&#xA;AND layer = 'Analytics'&#xA;AND PartitionProcessed = 0&#xA;&#xA;&#xA;&#xA;SELECT LoadDates, MAX(ETLBatchID) AS MAXETLBatchID&#xA;FROM @ProcessTable&#xA;WHERE LoadDates &gt;= 20170101&#xA;GROUP BY LoadDates&#xA;ORDER BY  LoadDates DESC"
              SQLTask:ResultType="ResultSetType_Rowset" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask">
              <SQLTask:ResultBinding
                SQLTask:ResultName="0"
                SQLTask:DtsVariableName="User::LoadDates" />
            </SQLTask:SqlTaskData>
