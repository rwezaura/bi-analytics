CREATE MEMBER CURRENTCUBE.[Measures].[Billed At 0 Without Revenue Duration - AR SVC MO]
 AS IIF([Measures].[Billed At 0 Without Revenue Duration in Seconds - AR SVC MO]=0 OR ISEMPTY([Measures].[Billed At 0 Without Revenue Duration in Seconds - AR SVC MO]),NULL,

[Measures].[Billed At 0 Without Revenue Duration in Seconds- AR SVC MO] / 60), 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Arrangement per Service Month';                                     
