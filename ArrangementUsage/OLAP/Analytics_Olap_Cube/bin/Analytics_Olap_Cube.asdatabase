          <Commands>
            <Command>
              <Text>/*
The CALCULATE command controls the aggregation of leaf cells in the cube.
If the CALCULATE command is deleted or modified, the data within the cube is affected.
You should edit this command only if you manually specify how the cube is aggregated.
*/
CALCULATE;                                                   
CREATE MEMBER CURRENTCUBE.[Measures].[Real Duration]
 AS IIF([Measures].[Real Duration in Seconds]=0 OR ISEMPTY([Measures].[Real Duration in Seconds]),NULL,

[Measures].[Real Duration in Seconds] / 60), 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Voice Service';          
                          
CREATE MEMBER CURRENTCUBE.[Measures].[Real Duration - Service]
 AS IIF([Measures].[Real Duration in Seconds - Service]=0 OR ISEMPTY([Measures].[Real Duration in Seconds - Service]),NULL,

[Measures].[Real Duration in Seconds - Service] / 60), 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Master Service Aggregate';                         
CREATE MEMBER CURRENTCUBE.[Measures].[Real Duration - AR SVC MO]
 AS IIF([Measures].[Real Duration in Seconds - AR SVC MO]=0 OR ISEMPTY([Measures].[Real Duration in Seconds - AR SVC MO]),NULL,

[Measures].[Real Duration in Seconds - AR SVC MO] / 60), 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Arrangement per Service Month';                                                 
CREATE MEMBER CURRENTCUBE.[Measures].[Billed Duration]
 AS IIF([Measures].[Billed Duration in Seconds]=0 OR ISEMPTY([Measures].[Billed Duration in Seconds]),NULL,

[Measures].[Billed Duration in Seconds] / 60), 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Voice Service';                                    
CREATE MEMBER CURRENTCUBE.[Measures].[Billed Duration - Service]
 AS IIF([Measures].[Billed Duration in Seconds - Service]=0 OR ISEMPTY([Measures].[Billed Duration in Seconds - Service]),NULL,

[Measures].[Billed Duration in Seconds - Service] / 60), 
FORMAT_STRING = "#,##0.00;-#,##0.00", 
VISIBLE = 1 ,  ASSOCIATED_MEASURE_GROUP = 'Master Service Aggregate';                         
CREATE MEMBER CURRENTCUBE.[Measures].[Billed Duration - AR SVC MO]
 AS IIF([Measures].[Billed Duration in Seconds - AR SVC MO]=0 OR ISEMPTY([Measures].[Billed Duration in Seconds - AR SVC MO]),NULL,

[Measures].[Billed Duration in Seconds - AR SVC MO] / 60), 
