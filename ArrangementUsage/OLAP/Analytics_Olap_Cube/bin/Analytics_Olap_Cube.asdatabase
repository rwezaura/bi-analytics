CREATE MEMBER CURRENTCUBE.[Measures].[Megabytes Downloaded - AR SVC MO]
 AS IIF([Measures].[Bytes Downloaded in Bytes - AR SVC MO]=0 OR ISEMPTY([Measures].[Bytes Downloaded in Bytes - AR SVC MO]),NULL,

[Measures].[Bytes Downloaded In Bytes - AR SVC MO] / 1024 / 1024), 
FORMAT_STRING = "#,##0;-#,##0", 
