 AS IIF([Measures].[Bytes At 0 Without Revenue Bytes in Bytes - AR SVC MO]=0 OR ISEMPTY([Measures].[Bytes At 0 Without Revenue Bytes in Bytes - AR SVC MO]),NULL,

[Measures].[Bytes At 0 Without Revenue Bytes in Bytes - AR SVC MO] / 1024 / 1024), 
