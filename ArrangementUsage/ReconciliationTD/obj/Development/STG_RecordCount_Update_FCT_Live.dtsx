              Name="st_7230f3c6d5db472e911bec0acb16612b"
              VSTAMajorVersion="15"
              VSTAMinorVersion="0"
              Language="VisualBasic">
              <ProjectItem
                Name="My Project\AssemblyInfo.vb"
                Encoding="UTF8"><![CDATA[Imports System
