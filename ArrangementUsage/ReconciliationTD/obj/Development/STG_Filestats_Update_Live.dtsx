="{f40fd7b6-902a-4149-9dcd-e9cad1d24843}_35" /&gt;&lt;com id="62" dir="TRAN" typ="trnrowcount" name="SRC OLE_SRC Get MMS" pid="{f40fd7b6-902a-4149-9dcd-e9cad1d24843}_62" /&gt;&lt;dp id="66" val="0" ann="" c1="35" c2="62"/&gt;&lt;dp id="67" val="0" ann="" c1="2" c2="6"/&gt;&lt;dp id="68" val="0" ann="" c1="62" c2="2"/&gt;&lt;/tsk&gt;&lt;tsk id="{8E9FDD12-D49A-4515-8E4B-C9284AD6E54E}" typ="PipelineTask" p="{F20B0943-0523-4B19-AD74-6970306F87F2}" name="DFT Update MON" on="1" &gt;&lt;com id="2" dir="TRAN" typ="trnrowcount" name="DEST OLE DB Destination" pid="{8E9FDD12-D49A-4515-8E4B-C9284AD6E54E}_2" /&gt;&lt;com id="6" dir="DEST" typ="desoledb" name="OLE DB Destination" pid="{8E9FDD12-D49A-4515-8E4B-C9284AD6E54E}_6" /&gt;&lt;com id="35" dir="SRC" typ="srcoledb" name="OLE_SRC Get MON" pid="{8E9FDD12-D49A-4515-8E4B-C9284AD6E54E}_35" /&gt;&lt;com id="62" dir="TRAN" typ="trnrowcount" name="SRC OLE_SRC Get MON" pid="{8E9FDD12-D49A-4515-8E4B-C9284AD6E54E}_62" /&gt;&lt;dp id="66" val="0" ann="" c1="35" c2="62"/&gt;&lt;dp id="67" val="0" ann="" c1="2" c2="6"/&gt;&lt;dp id="68" val="0" ann="" c1="62" c2="2"/&gt;&lt;/tsk&gt;&lt;tsk id="{B5D9CDDA-3729-468F-962E-99E386E80A93}" typ="PipelineTask" p="{F20B0943-0523-4B19-AD74-6970306F87F2}" name="DFT Update REC" on="1" &gt;&lt;com id="2" dir="TRAN" typ="trnrowcount" name="DEST OLE DB Destination" pid="{B5D9CDDA-3729-468F-962E-99E386E80A93}_2" /&gt;&lt;com id="6" dir="DEST" typ="desoledb" name="OLE DB Destination" pid="{B5D9CDDA-3729-468F-962E-99E386E80A93}_6" /&gt;&lt;com id="35" dir="SRC" typ="srcoledb" name="OLE_SRC Get REC" pid="{B5D9CDDA-3729-468F-962E-99E386E80A93}_35" /&gt;&lt;com id="62" dir="TRAN" typ="trnrowcount" name="SRC OLE_SRC Get REC" pid="{B5D9CDDA-3729-468F-962E-99E386E80A93}_62" /&gt;&lt;dp id="66" val="0" ann="" c1="35" c2="62"/&gt;&lt;dp id="67" val="0" ann="" c1="2" c2="6"/&gt;&lt;dp id="68" val="0" ann="" c1="62" c2="2"/&gt;&lt;/tsk&gt;&lt;tsk id="{ca89b9c2-e331-4ea3-b712-565d893a043f}" typ="PipelineTask" p="{F20