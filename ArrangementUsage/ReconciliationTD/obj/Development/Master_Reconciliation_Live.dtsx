    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{C17CE77E-5C60-4CBA-8A71-E2FEDA384F60}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="@[$Package::IsManualExecution] == 1 ? &quot;etl.Recon_FileStats_Stage&quot; : &quot;etl.Recon_FileStats_Stage_Live&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="FileStatsStaging">
      <DTS:VariableValue
        DTS:DataType="8">etl.Recon_FileStats_Stage</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{D0CE52B9-E7AD-4119-A66B-5F62D3ADC5F3}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @PPN_DT DATE = '&quot; + (DT_WSTR, 10) (DT_DBDATE) @[User::PPN_DT] + &quot;'&#xA;&#xA;UPDATE &#xA;&#x9; fs&#xA;&#xA;SET fs.StagingRecordCount = fss.StagingRecordCount, fs.StagingFileCount = fss.StagingFileCount&#xA;&#xA;&#xA;FROM&#xA;&#x9;etl.Recon_FileStats fs&#xA;&#xA;JOIN&#xA; &quot;&#xA; + @[User::FileStatsStaging]  +  &quot; fss with (nolock) &#xA;ON &#xA;&#x9;fs.FileType = fss.FileType &#xA;WHERE&#xA;&#x9;fs.ppn_dt = @PPN_DT&#xA;&#xA;&#xA;&#xA;&#xA;INSERT INTO etl.Recon_FileStats (FileCount, RecordCount, StagingRecordCount,StagingFileCount, PPN_DT, FileType)&#xA;&#xA;SELECT &#xA;&#x9;FSS.FileCount, FSS.RecordCount, FSS.StagingRecordCount,FSS.StagingFileCount,  FSS.PPN_DT, FSS.FileType&#xA;FROM&#xA;&#x9;&#xA;       &#xA; &quot;&#xA; + @[User::FileStatsStaging]  +  &quot; fss&#xA;&#xA;LEFT JOIN&#xA;&#x9;&#xA;        etl.Recon_FileStats fs&#xA;&#xA;ON&#xA;&#x9;fs.FileType = fss.FileType &#xA;&#xA;WHERE&#xA;&#x9;&#xA;        fs.ppn_dt  = @PPN_DT AND&#xA;&#x9;fss.ppn_dt = @PPN_DT AND &#xA;&#x9;fs.FileType IS NULL AND&#xA;        fss.FileType &lt;&gt; 'OCSSUB'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="JoinFileStats">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE @PPN_DT DATE = '2015-11-05'

UPDATE 
	 fs

SET fs.StagingRecordCount = fss.StagingRecordCount, fs.StagingFileCount = fss.StagingFileCount


FROM
	etl.Recon_FileStats fs

JOIN
 etl.Recon_FileStats_Stage fss with (nolock) 
ON 
	fs.FileType = fss.FileType 
WHERE
	fs.ppn_dt = @PPN_DT




INSERT INTO etl.Recon_FileStats (FileCount, RecordCount, StagingRecordCount,StagingFileCount, PPN_DT, FileType)

SELECT 
	FSS.FileCount, FSS.RecordCount, FSS.StagingRecordCount,FSS.StagingFileCount,  FSS.PPN_DT, FSS.FileType
FROM
	
       
 etl.Recon_FileStats_Stage fss

LEFT JOIN
	
        etl.Recon_FileStats fs

ON
	fs.FileType = fss.FileType 

WHERE
	
        fs.ppn_dt  = @PPN_DT AND
	fss.ppn_dt = @PPN_DT AND 
	fs.FileType IS NULL AND
        fss.FileType &lt;&gt; 'OCSSUB'</DTS:VariableValue>
    </DTS:Variable>
    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{C7F11EA7-A677-4ECA-BFAD-23B3ACC7478B}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;DECLARE @PPN_DT DATE =  '&quot; + (DT_WSTR, 10) (DT_DBDATE) @[User::PPN_DT] + &quot;'&#xA;&#xA;MERGE&#xA;&#x9;Recon_FileStats fs&#xA;USING &quot;&#xA;&#x9; + @[User::FileStatsStaging]  +  &quot; fss with (nolock)&#xA;ON&#xA;&#x9;fs.FileType = fss.FileType  AND fs.ppn_dt = @PPN_DT&#xA;&#x9;&#xA;WHEN MATCHED &#xA;&#x9;THEN &#xA;&#x9;&#x9;UPDATE SET fs.StagingRecordCount = fss.StagingRecordCount&#xA;WHEN NOT MATCHED &#xA;THEN&#xA;&#x9;INSERT ( FileName, RecordCount, StagingRecordCount, PPN_DT, FileType )&#xA;&#x9;VALUES ( FSS.FileName, 0, fss.StagingRecordCount, @PPN_DT, fss.FileType );&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="MergeFileStats">
      <DTS:VariableValue
        DTS:DataType="8">DECLARE @PPN_DT DATE =  '2015-11-05'

MERGE
	Recon_FileStats fs
USING etl.Recon_FileStats_Stage fss with (nolock)
ON
	fs.FileType = fss.FileType  AND fs.ppn_dt = @PPN_DT
	
WHEN MATCHED 
	THEN 
		UPDATE SET fs.StagingRecordCount = fss.StagingRecordCount
WHEN NOT MATCHED 
THEN
	INSERT ( FileName, RecordCount, StagingRecordCount, PPN_DT, FileType )
	VALUES ( FSS.FileName, 0, fss.StagingRecordCount, @PPN_DT, fss.FileType );</DTS:VariableValue>
    </DTS:Variable>
