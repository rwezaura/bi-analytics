                <component
                  refId="Package\Sequence Container\DFT Get Dates To Reconcile\LKP Get LastUpdatedDate by PPN_DT from Recon_RecordCount"
                  componentClassID="Microsoft.Lookup"
                  contactInfo="Lookup;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;6"
                  description="Joins additional columns to the data flow by looking up values in a table. For example, join to the 'employee id' column the employees table to get 'hire date' and 'employee name'. We recommend this transformation when the lookup table can fit into memory."
                  name="LKP Get LastUpdatedDate by PPN_DT from Recon_RecordCount"
                  usesDispositions="true"
                  version="6">
                  <properties>
                    <property
                      dataType="System.String"
                      description="Specifies the SQL statement that generates the lookup table."
                      expressionType="Notify"
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">WITH
	GetDates
AS
 (
	select getdate()-30 as getdt
	)
	,


DatesToProcess as (

	Select getdt 
	from GetDates
	union all
	select getdt + 1 
	from 
		DatesToProcess
	where DatesToProcess.getdt &lt;= getdate() - 2

	)

SELECT 
	CONVERT(DATE, getdt) as ppn_dt,
	(NULL) AS LastUpdatedDate
FROM
	DatesToProcess

EXCEPT

SELECT 
	DISTINCT cast(cast(ADATE as varchar) as date),
	(NULL)
FROM
	etl.Recon_RecordCount Where adate &gt;= '20150401'

UNION

SELECT 
	CAST(CAST(Adate as varchar) as date) AS PPN_DT,
	MAX(LastUpdatedDate) LastUpdateDate
FROM 
	etl.Recon_RecordCount
WHERE
	LastUpdatedDate IS NOT NULL
GROUP BY
	CAST(CAST(adate as varchar) as date)
ORDER BY
	PPN_DT</property>
                    <property
                      dataType="System.String"
                      description="Specifies a SQL statement that uses parameters to generate the lookup table."
                      expressionType="Notify"
                      name="SqlCommandParam"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=15.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">select * from (WITH
	GetDates
AS
 (
	select getdate()-30 as getdt
	)
	,


DatesToProcess as (

	Select getdt 
	from GetDates
	union all
	select getdt + 1 
	from 
		DatesToProcess
	where DatesToProcess.getdt &lt;= getdate() - 2

	)

SELECT 
	CONVERT(DATE, getdt) as ppn_dt,
	(NULL) AS LastUpdatedDate
FROM
	DatesToProcess

EXCEPT

SELECT 
	DISTINCT cast(cast(ADATE as varchar) as date),
	(NULL)
FROM
	etl.Recon_RecordCount Where adate &gt;= '20150401'

UNION

SELECT 
	CAST(CAST(Adate as varchar) as date) AS PPN_DT,
	MAX(LastUpdatedDate) LastUpdateDate
FROM 
	etl.Recon_RecordCount
WHERE
	LastUpdatedDate IS NOT NULL
GROUP BY
	CAST(CAST(adate as varchar) as date)
ORDER BY
	PPN_DT) [refTable]
where [refTable].[ppn_dt] = ?</property>
