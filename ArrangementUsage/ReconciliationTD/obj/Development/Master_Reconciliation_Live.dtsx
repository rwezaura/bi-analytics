    <DTS:Variable
      DTS:CreationName=""
      DTS:DTSID="{781B148A-17D5-4B9E-BCE4-D6F2AAFAC203}"
      DTS:EvaluateAsExpression="True"
      DTS:Expression="&quot;update fs&#xA;&#x9; set fs.StagingRecordCount = fss.StagingRecordCount, fs.StagingFileCount = fss.StagingFileCount&#xA;FROM &#xA;&#x9;Recon_FileStats fs with (nolock)&#xA;&#x9;join &quot; + @[User::FileStatsStaging]  + &quot; fss with (nolock) on fs.FileType = fss.FileType&#x9;where fs.PPN_DT = '&quot; +  (DT_WSTR, 10) (DT_DBDATE) @[User::PPN_DT]  + &quot;' and fss.PPN_DT = '&quot; +  (DT_WSTR, 10) (DT_DBDATE) @[User::PPN_DT]  + &quot;'&quot;"
      DTS:IncludeInDebugDump="2345"
      DTS:Namespace="User"
      DTS:ObjectName="UpdateFileStats_RecordCount">
      <DTS:VariableValue
        DTS:DataType="8">update fs
	 set fs.StagingRecordCount = fss.StagingRecordCount, fs.StagingFileCount = fss.StagingFileCount
FROM 
	Recon_FileStats fs with (nolock)
	join etl.Recon_FileStats_Stage fss with (nolock) on fs.FileType = fss.FileType	where fs.PPN_DT = '2015-11-05' and fss.PPN_DT = '2015-11-05'</DTS:VariableValue>
    </DTS:Variable>
